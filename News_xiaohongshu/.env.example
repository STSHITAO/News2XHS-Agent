APP_NAME=News2XHS-Agent
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=5100
LOG_LEVEL=INFO

# Database (MySQL recommended)
DATABASE_URL=
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456789
DB_NAME=news_xiaohongshu
DB_CHARSET=utf8mb4

# Search provider route (AnspireAPI / BochaAPI / TavilyAPI)
SEARCH_TOOL_TYPE=AnspireAPI
ENABLE_FUNCTION_CALLING=True

# Optional function-calling model (OpenAI-compatible Qwen endpoint)
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=Qwen/Qwen2.5-72B-Instruct
QWEN_TIMEOUT=90

# Search provider keys
ANSPIRE_API_KEY=
ANSPIRE_BASE_URL=https://plugin.anspire.cn/api/ntsearch/search
BOCHA_WEB_SEARCH_API_KEY=
BOCHA_BASE_URL=https://api.bocha.cn/v1/ai-search
TAVILY_API_KEY=

# Text-to-image model (cover generation)
# Provider: MockAPI (local test), OpenAICompatible (real model endpoint)
IMAGE_GEN_PROVIDER=MockAPI
IMAGE_GEN_API_KEY=
# Example: https://dashscope.aliyuncs.com/compatible-mode/v1
IMAGE_GEN_BASE_URL=
# Example: qwen-image / flux / your_image_model_name
IMAGE_GEN_MODEL=
IMAGE_GEN_TIMEOUT=120
IMAGE_GEN_DEFAULT_SIZE=1024x1024
IMAGE_GEN_OUTPUT_DIR=static/uploads/covers/generated
AUTO_GENERATE_COVER_ON_DRAFT=True
AUTO_GENERATE_COVER_STRICT=False

# Xiaohongshu MCP service
XHS_MCP_BASE_URL=http://127.0.0.1:18060
# Optional: only fill when your MCP gateway enforces Bearer auth
XHS_MCP_API_KEY=
XHS_PUBLISH_TIMEOUT=180
PUBLISH_GUARD_TOKEN=

# Cover strategy: local only (disable crawler/screenshot image)
LOCAL_COVER_ONLY=True
# Default local cover image path (can be absolute path)
DEFAULT_LOCAL_COVER_IMAGE_PATH=./DJI_20240603095231_0001_D_bottom_left.JPG

# Scheduler
SCHEDULER_ENABLED=True
HOT_NEWS_DEFAULT_QUERY=热点新闻
HOT_NEWS_INTERVAL_MINUTES=30
HOT_NEWS_DEFAULT_LIMIT=20
